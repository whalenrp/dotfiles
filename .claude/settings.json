{
  "alwaysThinkingEnabled": true,
  "apiKeyHelper": "/home/user/.local/share/aifx/bin/claude-genai-token-helper",
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "support-engineer@agent-marketplace": true,
    "uber-reviewer@agent-marketplace": true
  },
  "env": {
    "ENABLE_TOOL_SEARCH": "false"
  },
  "fastMode": false,
  "model": "opus[1m]",
  "otelHeadersHelper": "/home/user/.local/share/aifx/bin/claude-telemetry-token-helper",
  "permissions": {
    "allow": [
      "Bash(bazel:*)",
      "mcp__monorepo-experts-mcp-server__generate_standard_go_mocks",
      "mcp__monorepo-experts-mcp-server__generate_glue_go_mocks",
      "mcp__monorepo-experts-mcp-server__update_build_files",
      "mcp__monorepo-experts-mcp-server__get_coverage_report"
    ],
    "ask": [],
    "deny": []
  },
  "skipDangerousModePermissionPrompt": true,
  "statusLine": {
    "command": "bash /home/user/.claude/statusline.sh",
    "type": "command"
  }
}